# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing — never commit keystore or credentials
android/key.properties
android/*.jks
android/*.keystore
android/app/*.jks
android/app/*.keystore

# JVM / native crash dumps
hs_err_pid*.log
android/hs_err_pid*.log
replay_pid*.log

# Local Gradle / Flutter generated
android/local.properties
android/.gradle/
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Pods/
ios/.symlinks/
